<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Microsoft.PowerShell.Commands.Utility</id>
    <version>7.4.6</version>
    <authors>Microsoft</authors>
    <owners>Microsoft,PowerShell</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>Powershell_black_64.png</icon>
    <projectUrl>https://github.com/PowerShell/PowerShell</projectUrl>
    <description>Runtime for hosting PowerShell</description>
    <copyright>© Microsoft Corporation. All rights reserved.</copyright>
    <language>en-US</language>
    <tags>PowerShell</tags>
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="System.Management.Automation" version="7.4.6" />
        <dependency id="Markdig.Signed" version="0.33.0" />
        <dependency id="Microsoft.PowerShell.MarkdownRender" version="7.2.1" />
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="4.9.2" />
        <dependency id="System.Threading.AccessControl" version="9.0.0-preview.6.24327.7" />
        <dependency id="System.Drawing.Common" version="9.0.0-preview.6.24327.6" />
        <dependency id="JsonSchema.Net" version="7.0.4" />
      </group>
    </dependencies>
    <contentFiles>
      <files include="**/*" buildAction="None" copyToOutput="true" flatten="false" />
    </contentFiles>
  </metadata>
</package>