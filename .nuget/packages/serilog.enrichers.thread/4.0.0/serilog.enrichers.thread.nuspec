    <icon>serilog-enricher-nuget.png</icon>
    <readme>README.md</readme>
    <projectUrl>http://serilog.net/</projectUrl>
    <description>Enrich Serilog events with properties from the current thread.</description>
    <tags>serilog thread enricher</tags>
    <repository type="git" url="https://github.com/serilog/serilog-enrichers-thread.git" commit="a6c1b7b56e9e11af8b1ce47273ed4beb38fcbf24" />
