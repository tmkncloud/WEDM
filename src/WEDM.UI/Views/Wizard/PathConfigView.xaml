<UserControl x:Class="WEDM.UI.Views.Wizard.PathConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Wizard"
             xmlns:converters="clr-namespace:WEDM.UI.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PathConfigViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- Auto-populate toggle -->
            <Border CornerRadius="6" Padding="14,10"
                    Margin="0,0,0,20"
                    Background="{StaticResource AccentSubtleBrush}">
                <CheckBox Content="Auto-populate paths from Oracle Root directory"
                          Style="{StaticResource CheckBoxStyle}"
                          IsChecked="{Binding AutoPopulatePaths}"/>
            </Border>

            <!-- Oracle Root -->
            <TextBlock Text="Oracle Root Directory" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource TextBoxStyle}"
                         Text="{Binding OracleRoot, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="Browse…"
                        Style="{StaticResource BtnSecondary}"
                        Command="{Binding BrowseOracleRootCommand}"
                        Margin="8,0,0,0" Padding="12,0"/>
            </Grid>
            <TextBlock Text="{Binding OracleRootError}"
                       Foreground="{StaticResource DangerBrush}"
                       Style="{StaticResource TypeCaption}"
                       Visibility="{Binding OracleRootError, Converter={StaticResource StringToVis}}"
                       Margin="0,0,0,12"/>

            <!-- Middleware Home -->
            <TextBlock Text="Middleware Home (ORACLE_HOME)" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource TextBoxStyle}"
                         Text="{Binding MiddlewareHome, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="Browse…"
                        Style="{StaticResource BtnSecondary}"
                        Command="{Binding BrowseMiddlewareHomeCommand}"
                        Margin="8,0,0,0" Padding="12,0"/>
            </Grid>
            <TextBlock Text="{Binding MiddlewareHomeError}"
                       Foreground="{StaticResource DangerBrush}"
                       Style="{StaticResource TypeCaption}"
                       Visibility="{Binding MiddlewareHomeError, Converter={StaticResource StringToVis}}"
                       Margin="0,0,0,12"/>

            <!-- Domain Base -->
            <TextBlock Text="Domain Base Directory" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource TextBoxStyle}"
                         Text="{Binding DomainBase, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="Browse…"
                        Style="{StaticResource BtnSecondary}"
                        Command="{Binding BrowseDomainBaseCommand}"
                        Margin="8,0,0,0" Padding="12,0"/>
            </Grid>
            <TextBlock Text="{Binding DomainBaseError}"
                       Foreground="{StaticResource DangerBrush}"
                       Style="{StaticResource TypeCaption}"
                       Visibility="{Binding DomainBaseError, Converter={StaticResource StringToVis}}"
                       Margin="0,0,0,12"/>

            <Separator Background="{StaticResource BorderSubtleBrush}" Margin="0,8,0,20"/>

            <!-- Secondary paths -->
            <TextBlock Text="Additional Directories" Style="{StaticResource TypeH3}" Margin="0,0,0,12"/>

            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,8,12">
                    <TextBlock Text="Oracle Inventory" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource TextBoxStyle}"
                             Text="{Binding OracleInventory, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="8,0,0,12">
                    <TextBlock Text="Temp Directory" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource TextBoxStyle}"
                             Text="{Binding TempDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,12">
                    <TextBlock Text="Log Directory" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource TextBoxStyle}"
                             Text="{Binding LogDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="8,0,0,12">
                    <TextBlock Text="Reports Directory" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource TextBoxStyle}"
                             Text="{Binding ReportsDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
