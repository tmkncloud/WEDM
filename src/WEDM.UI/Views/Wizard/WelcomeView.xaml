<UserControl x:Class="WEDM.UI.Views.Wizard.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Wizard"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:WelcomeViewModel, IsDesignTimeCreatable=False}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="6" Margin="0,0,0,12" Padding="14,12"
                Background="{DynamicResource BackgroundPanelBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{Binding WelcomeHeadline}" Style="{StaticResource TypeH1}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding WelcomeSubheadline}" Style="{StaticResource TypeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}"
                           Style="{StaticResource TypeCaption}" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                Background="{DynamicResource BackgroundPanelBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Environment profile" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <ComboBox Style="{StaticResource ComboBoxStyle}" Width="220" HorizontalAlignment="Left"
                          ItemsSource="{Binding DeploymentEnvironmentOptions}"
                          SelectedItem="{Binding SelectedDeploymentEnvironment}"/>
                <TextBlock Text="DEV = relaxed automation; SIT/UAT = online WLST + nmEnroll; PROD = strict validation and SSL-oriented Node Manager defaults."
                           Style="{StaticResource TypeCaption}" TextWrapping="Wrap" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="What WEDM automates" Style="{StaticResource TypeH2}" Margin="0,0,0,8"/>

        <ItemsControl Grid.Row="3" ItemsSource="{Binding FeatureHighlights}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="4" Margin="0,0,6,6" Padding="10,8"
                            Background="{DynamicResource BackgroundPanelBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓ " Foreground="{DynamicResource SuccessBrush}"
                                       Style="{StaticResource TypeBody}" VerticalAlignment="Top" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding}" Style="{StaticResource TypeBody}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="4" CornerRadius="4" Padding="10,8" Margin="0,12,0,0"
                Background="{DynamicResource WarningSubtleBrush}"
                BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1">
            <TextBlock Style="{StaticResource TypeCaption}" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap">
                WEDM requires Administrator privileges and modifies system environment variables, the Windows Registry, and Oracle installations. Ensure you have a current backup before proceeding.
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
