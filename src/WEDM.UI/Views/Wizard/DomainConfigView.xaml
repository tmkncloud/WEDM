<UserControl x:Class="WEDM.UI.Views.Wizard.DomainConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Wizard"
             xmlns:converters="clr-namespace:WEDM.UI.Converters"
             xmlns:val="clr-namespace:WEDM.UI.Validation"
             xmlns:behaviors="clr-namespace:WEDM.UI.Behaviors"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DomainConfigViewModel, IsDesignTimeCreatable=False}">
    <StackPanel>
        <StackPanel.Resources>
            <converters:StringToVisibilityConverter x:Key="StringToVis"/>
            <converters:StringToBoolConverter x:Key="StringToBool"/>
        </StackPanel.Resources>
        <TextBlock Text="Topology" Style="{StaticResource TypeH2}" Margin="0,0,0,8"/>
        <TextBlock Text="{Binding ProfileSummary}" Style="{StaticResource TypeCaption}"
                   Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <ItemsControl ItemsSource="{Binding TopologyNodes}" Margin="0,0,0,16">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8" Padding="14,12" Margin="0,0,10,0" MinWidth="140"
                            Background="{StaticResource BackgroundPanelBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding StatusGlyph}" FontSize="18" HorizontalAlignment="Right"
                                       Foreground="{StaticResource AccentPrimaryBrush}"/>
                            <TextBlock Text="{Binding Role}" Style="{StaticResource TypeCaption}"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding Name}" Style="{StaticResource TypeH3}" Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding Port, StringFormat=Port {0}}" Style="{StaticResource TypeMono}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Domain Identity" Style="{StaticResource TypeH2}" Margin="0,0,0,12"/>
        <UniformGrid Columns="2" Margin="0,0,0,18">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Domain Name" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding DomainName, UpdateSourceTrigger=PropertyChanged}"
                         val:ValidationProperties.HasError="{Binding DomainNameError, Converter={StaticResource StringToBool}}"/>
                <TextBlock Text="{Binding DomainNameError}" Style="{StaticResource ValidationErrorText}"
                           Visibility="{Binding DomainNameError, Converter={StaticResource StringToVis}}"/>
            </StackPanel>
            <StackPanel Margin="8,0,0,0">
                <TextBlock Text="Topology" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <ComboBox Style="{StaticResource ComboBoxStyle}"
                          ItemsSource="{Binding Topologies}"
                          SelectedItem="{Binding Topology}"/>
            </StackPanel>
        </UniformGrid>

        <TextBlock Text="Admin Server" Style="{StaticResource TypeH2}" Margin="0,0,0,12"/>
        <UniformGrid Columns="3" Margin="0,0,0,14">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Server Name" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding AdminServerName, UpdateSourceTrigger=PropertyChanged}"
                         val:ValidationProperties.HasError="{Binding AdminServerNameError, Converter={StaticResource StringToBool}}"/>
                <TextBlock Text="{Binding AdminServerNameError}" Style="{StaticResource ValidationErrorText}"
                           Visibility="{Binding AdminServerNameError, Converter={StaticResource StringToVis}}"/>
            </StackPanel>
            <StackPanel Margin="4,0,8,0">
                <TextBlock Text="Listen Port" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding AdminPort, UpdateSourceTrigger=PropertyChanged}"
                         val:ValidationProperties.HasError="{Binding AdminPortError, Converter={StaticResource StringToBool}}"/>
                <TextBlock Text="{Binding AdminPortError}" Style="{StaticResource ValidationErrorText}"
                           Visibility="{Binding AdminPortError, Converter={StaticResource StringToVis}}"/>
            </StackPanel>
            <StackPanel Margin="4,0,0,0">
                <TextBlock Text="SSL Port" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding AdminSslPort, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </UniformGrid>

        <UniformGrid Columns="3" Margin="0,0,0,20">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Administrator User" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding AdminUsername, UpdateSourceTrigger=PropertyChanged}"
                         val:ValidationProperties.HasError="{Binding AdminUsernameError, Converter={StaticResource StringToBool}}"/>
                <TextBlock Text="{Binding AdminUsernameError}" Style="{StaticResource ValidationErrorText}"
                           Visibility="{Binding AdminUsernameError, Converter={StaticResource StringToVis}}"/>
            </StackPanel>
            <StackPanel Margin="4,0,8,0">
                <TextBlock Text="Password" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <PasswordBox Style="{StaticResource PasswordBoxStyle}"
                             behaviors:PasswordBoxBinding.BindPassword="True"
                             behaviors:PasswordBoxBinding.BoundPassword="{Binding AdminPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             val:ValidationProperties.HasError="{Binding AdminPasswordError, Converter={StaticResource StringToBool}}"/>
                <TextBlock Text="{Binding AdminPasswordError}" Style="{StaticResource ValidationErrorText}"
                           Visibility="{Binding AdminPasswordError, Converter={StaticResource StringToVis}}"/>
            </StackPanel>
            <StackPanel Margin="4,0,0,0">
                <TextBlock Text="Confirm Password" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <PasswordBox Style="{StaticResource PasswordBoxStyle}"
                             behaviors:PasswordBoxBinding.BindPassword="True"
                             behaviors:PasswordBoxBinding.BoundPassword="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             val:ValidationProperties.HasError="{Binding ConfirmPasswordError, Converter={StaticResource StringToBool}}"/>
                <TextBlock Text="{Binding ConfirmPasswordError}" Style="{StaticResource ValidationErrorText}"
                           Visibility="{Binding ConfirmPasswordError, Converter={StaticResource StringToVis}}"/>
            </StackPanel>
        </UniformGrid>

        <TextBlock Text="Node Manager" Style="{StaticResource TypeH2}" Margin="0,0,0,12"/>
        <TextBlock Text="{Binding NodeManagerStatusHint}" Style="{StaticResource TypeCaption}"
                   Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <UniformGrid Columns="3" Margin="0,0,0,20">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Port" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NodeManagerPort, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Margin="4,0,8,0">
                <TextBlock Text="Type" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <ComboBox Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding NmTypes}" SelectedItem="{Binding NodeManagerType}"/>
            </StackPanel>
            <CheckBox Content="Register Node Manager Windows service"
                      Style="{StaticResource CheckBoxStyle}"
                      IsChecked="{Binding RegisterNmService}"
                      VerticalAlignment="Bottom" Margin="4,0,0,9"/>
        </UniformGrid>

        <Grid Margin="0,0,0,12">
            <TextBlock Text="Managed Servers" Style="{StaticResource TypeH2}" VerticalAlignment="Center"/>
            <Button Content="Add Managed Server" Style="{StaticResource BtnSecondary}"
                    Command="{Binding AddManagedServerCommand}"
                    HorizontalAlignment="Right" Width="170"/>
        </Grid>

        <ItemsControl ItemsSource="{Binding ManagedServers}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="6" Padding="12" Margin="0,0,0,8"
                            Background="{StaticResource BackgroundPanelBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource TextBoxStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource TextBoxStyle}" Text="{Binding SslPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                            <CheckBox Grid.Column="3" Content="Service" Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding RegisterService}" Margin="0,0,12,0"/>
                            <Button Grid.Column="4" Content="Remove" Style="{StaticResource BtnGhost}"
                                    Command="{Binding DataContext.RemoveManagedServerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" Width="90"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
