<UserControl x:Class="WEDM.UI.Views.Wizard.DeploymentSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Wizard"
             xmlns:converters="clr-namespace:WEDM.UI.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DeploymentSummaryViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel>
        <UniformGrid Columns="2" Margin="0,0,0,16">
            <Border CornerRadius="8" Padding="16" Margin="0,0,8,8" Background="{StaticResource BackgroundPanelBrush}">
                <StackPanel>
                    <TextBlock Text="Version" Style="{StaticResource TypeH3}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding VersionSummary}" Style="{StaticResource TypeMono}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="8" Padding="16" Margin="8,0,0,8" Background="{StaticResource BackgroundPanelBrush}">
                <StackPanel>
                    <TextBlock Text="Paths" Style="{StaticResource TypeH3}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding PathSummary}" Style="{StaticResource TypeMono}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="8" Padding="16" Margin="0,8,8,0" Background="{StaticResource BackgroundPanelBrush}">
                <StackPanel>
                    <TextBlock Text="Domain" Style="{StaticResource TypeH3}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding DomainSummary}" Style="{StaticResource TypeMono}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="8" Padding="16" Margin="8,8,0,0" Background="{StaticResource BackgroundPanelBrush}">
                <StackPanel>
                    <TextBlock Text="Database" Style="{StaticResource TypeH3}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding DatabaseSummary}" Style="{StaticResource TypeMono}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                Background="{StaticResource AccentSubtleBrush}"
                BorderBrush="{StaticResource AccentPrimaryBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Security &amp; hardening" Style="{StaticResource TypeH3}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding SecurityHardeningSummary}" Style="{StaticResource TypeMono}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border CornerRadius="8" Padding="16" Margin="0,0,0,16" Background="{StaticResource BackgroundPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Deployment Manifest" Style="{StaticResource TypeH3}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ComponentSummary}" Style="{StaticResource TypeMono}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Show JSON" Style="{StaticResource BtnSecondary}"
                        Command="{Binding ToggleJsonCommand}" Width="110" Margin="12,0,8,0"/>
                <Button Grid.Column="2" Content="Export" Style="{StaticResource BtnSecondary}"
                        Command="{Binding ExportConfigCommand}" Width="90"/>
            </Grid>
        </Border>

        <TextBox Text="{Binding ConfigJson}" Style="{StaticResource TextBoxMono}"
                 AcceptsReturn="True" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Height="220"
                 Visibility="{Binding ShowJson, Converter={StaticResource BoolToVis}}"
                 Margin="0,0,0,16"/>

        <Border CornerRadius="6" Padding="14,10" Background="{StaticResource WarningSubtleBrush}">
            <CheckBox Style="{StaticResource CheckBoxStyle}"
                      IsChecked="{Binding TermsAccepted}">
                <TextBlock Text="I confirm this deployment may install Oracle software, create domains, register Windows services, and modify system configuration."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource WarningBrush}"/>
            </CheckBox>
        </Border>
    </StackPanel>
</UserControl>
