<UserControl x:Class="WEDM.UI.Views.Wizard.PrerequisiteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Wizard"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PrerequisiteViewModel, IsDesignTimeCreatable=False}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                Background="{StaticResource BackgroundPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="System Readiness" Style="{StaticResource TypeH2}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SummaryMessage}" Style="{StaticResource TypeBody}"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource TypeCaption}"
                               Foreground="{StaticResource DangerBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Run Checks"
                        Style="{StaticResource BtnPrimary}"
                        Command="{Binding RunChecksCommand}"
                        Width="130"/>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
            <Border CornerRadius="6" Padding="14" Margin="0,0,8,0" Background="{StaticResource SuccessSubtleBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding PassCount}" Style="{StaticResource TypeH1}" Foreground="{StaticResource SuccessBrush}"/>
                    <TextBlock Text="Passed" Style="{StaticResource TypeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="6" Padding="14" Margin="4,0,8,0" Background="{StaticResource WarningSubtleBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding WarnCount}" Style="{StaticResource TypeH1}" Foreground="{StaticResource WarningBrush}"/>
                    <TextBlock Text="Warnings" Style="{StaticResource TypeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="6" Padding="14" Margin="4,0,0,0" Background="#2D0F0E">
                <StackPanel>
                    <TextBlock Text="{Binding ErrorCount}" Style="{StaticResource TypeH1}" Foreground="{StaticResource DangerBrush}"/>
                    <TextBlock Text="Errors" Style="{StaticResource TypeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" CornerRadius="8" Background="{StaticResource BackgroundPanelBrush}">
            <DataGrid ItemsSource="{Binding Findings}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      Background="Transparent"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource BackgroundElevatedBrush}"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="42">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusIcon}" Foreground="{Binding StatusColor}"
                                           FontSize="14" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Check" Binding="{Binding CheckName}" Width="180"/>
                    <DataGridTextColumn Header="Result" Binding="{Binding Message}" Width="2*"/>
                    <DataGridTextColumn Header="Remediation" Binding="{Binding Remediation}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
