<UserControl x:Class="WEDM.UI.Views.Wizard.DeploymentProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Wizard"
             xmlns:converters="clr-namespace:WEDM.UI.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DeploymentProgressViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="8" Padding="18" Margin="0,0,0,16"
                Background="{StaticResource BackgroundPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding CurrentStepName}" Style="{StaticResource TypeH2}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CurrentStepDescription}" Style="{StaticResource TypeBody}"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding FinalStatusMessage}" Style="{StaticResource TypeCaption}"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Cancel" Style="{StaticResource BtnDanger}"
                            Command="{Binding CancelDeploymentCommand}"
                            Width="100" Margin="0,0,8,0"/>
                    <Button Content="Open Report" Style="{StaticResource BtnSecondary}"
                            Command="{Binding OpenReportCommand}"
                            Width="120"/>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
            <Border CornerRadius="6" Padding="14" Margin="0,0,8,0" Background="{StaticResource AccentSubtleBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding OverallProgressLabel}" Style="{StaticResource TypeH1}" Foreground="{StaticResource AccentPrimaryBrush}"/>
                    <TextBlock Text="Overall Progress" Style="{StaticResource TypeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="6" Padding="14" Margin="4,0,8,0" Background="{StaticResource BackgroundPanelBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding ElapsedTime}" Style="{StaticResource TypeH1}"/>
                    <TextBlock Text="Elapsed Time" Style="{StaticResource TypeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="6" Padding="14" Margin="4,0,0,0" Background="{StaticResource BackgroundPanelBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding ReportPath}" Style="{StaticResource TypeCaption}" TextWrapping="Wrap"/>
                    <TextBlock Text="Report Target" Style="{StaticResource TypeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" Padding="12" Margin="0,0,12,0"
                    Background="{StaticResource BackgroundPanelBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Workflow Steps" Style="{StaticResource TypeH3}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding StepStatuses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,0,0,6" CornerRadius="5"
                                        Background="{StaticResource BackgroundElevatedBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="54"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding StepName}" Style="{StaticResource TypeCaption}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Margin="0,6,8,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Duration}" Style="{StaticResource TypeCaption}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" CornerRadius="8" Padding="12" Background="{StaticResource BackgroundPanelBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Live Deployment Log" Style="{StaticResource TypeH3}" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding LogEntries}"
                             Background="{StaticResource BackgroundDeepBrush}"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                               Style="{StaticResource TypeMono}"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LevelIcon}" Foreground="{Binding LevelColor}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Message}"
                                               Style="{StaticResource TypeMono}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
