<UserControl x:Class="WEDM.UI.Views.Wizard.OperationSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Wizard"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:OperationSelectionViewModel, IsDesignTimeCreatable=False}">

    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,28">
            <TextBlock Text="How would you like to use WEDM?"
                       Style="{StaticResource TypeH2}"/>
            <TextBlock Text="Select an operation mode to begin. Deployment and migration workflows are fully separated with dedicated configuration models and validation pipelines."
                       Style="{StaticResource TypeBody}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,24">

            <!-- Deploy New Environment -->
            <Button Command="{Binding SelectDeployCommand}"
                    Margin="0,0,12,0"
                    Height="Auto"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDeploySelected}" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Border CornerRadius="12" Padding="28,32" MinHeight="280">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BackgroundPanelBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDeploySelected}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="🚀" FontSize="44" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Deploy New Environment"
                                   Style="{StaticResource TypeH1}"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Greenfield Oracle WebLogic, Forms &amp; Reports, JDK, domain, OPatch, and security automation."
                                   Style="{StaticResource TypeBody}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <Border CornerRadius="4" Padding="10,4" Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                Background="{StaticResource SuccessSubtleBrush}">
                            <TextBlock Text="Full deployment wizard"
                                       Style="{StaticResource TypeCaption}"
                                       Foreground="{StaticResource SuccessBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Button>

            <!-- Upgrade / Migrate -->
            <Button Command="{Binding SelectMigrateCommand}"
                    Margin="12,0,0,0"
                    Height="Auto"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Button.Style>
                <Border CornerRadius="12" Padding="28,32" MinHeight="280">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BackgroundPanelBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMigrateSelected}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="🔄" FontSize="44" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Upgrade / Migrate Existing"
                                   Style="{StaticResource TypeH1}"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Middleware modernization — discovery, compatibility assessment, upgrade path planning, and migration orchestration."
                                   Style="{StaticResource TypeBody}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <Border CornerRadius="4" Padding="10,4" Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                Background="{StaticResource AccentSubtleBrush}">
                            <TextBlock Text="Migration workflow"
                                       Style="{StaticResource TypeCaption}"
                                       Foreground="{StaticResource AccentPrimaryBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Button>

            <!-- Remove WebLogic Environment -->
            <Button Command="{Binding SelectDecommissionCommand}"
                    Margin="12,0,0,0"
                    Height="Auto"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Button.Style>
                <Border CornerRadius="12" Padding="28,32" MinHeight="280">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BackgroundPanelBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDecommissionSelected}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="🧹" FontSize="44" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Remove WebLogic Environment"
                                   Style="{StaticResource TypeH1}"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Oracle-aware decommission — discovery, inventory detach, graceful shutdown, and environment sanitization."
                                   Style="{StaticResource TypeBody}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <Border CornerRadius="4" Padding="10,4" Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                Background="{StaticResource BackgroundElevatedBrush}">
                            <TextBlock Text="Decommission workflow"
                                       Style="{StaticResource TypeCaption}"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Button>
        </UniformGrid>

        <Border Grid.Row="2" CornerRadius="6" Padding="14,10"
                Background="{StaticResource BackgroundElevatedBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1">
            <TextBlock Style="{StaticResource TypeCaption}"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap">
                WEDM separates deployment and migration configuration, validation, and orchestration.
                Phase 1 migration provides discovery, compatibility assessment, and planning foundations —
                execution orchestration integrates in a future release.
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
