<UserControl x:Class="WEDM.UI.Views.Shell.ActivityBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels"
             Width="{DynamicResource ActivityBarWidth}"
             Background="{DynamicResource BackgroundElevatedBrush}"
             BorderBrush="{DynamicResource BorderSubtleBrush}"
             BorderThickness="0,0,1,0">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top nav items fill -->
            <RowDefinition Height="*"/>
            <!-- Bottom items (Settings) stick to bottom -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top navigation items -->
        <ItemsControl Grid.Row="0"
                      ItemsSource="{Binding TopItems}"
                      Focusable="False"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ActivityBarItemViewModel}">
                    <Button Command="{Binding ActivateCommand}"
                            ToolTip="{Binding Tooltip}"
                            ToolTipService.InitialShowDelay="300"
                            Style="{StaticResource ActivityBarButtonStyle}"
                            IsEnabled="True">
                        <Grid>
                            <!-- Active indicator: 3px left accent bar -->
                            <Border HorizontalAlignment="Left"
                                    Width="3"
                                    CornerRadius="0,2,2,0"
                                    Margin="0,6,0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!-- Icon glyph -->
                            <TextBlock Text="{Binding IconGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Badge overlay -->
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,6,6,0"
                                    Width="14" Height="14"
                                    CornerRadius="7"
                                    Background="{DynamicResource DangerBrush}"
                                    Visibility="{Binding HasBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding BadgeCount}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Bottom items (Settings, etc.) -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding BottomItems}"
                      Focusable="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ActivityBarItemViewModel}">
                    <Button Command="{Binding ActivateCommand}"
                            ToolTip="{Binding Tooltip}"
                            ToolTipService.InitialShowDelay="300"
                            Style="{StaticResource ActivityBarButtonStyle}">
                        <Grid>
                            <Border HorizontalAlignment="Left"
                                    Width="3"
                                    CornerRadius="0,2,2,0"
                                    Margin="0,6,0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="{Binding IconGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
