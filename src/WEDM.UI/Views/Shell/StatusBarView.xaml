<UserControl x:Class="WEDM.UI.Views.Shell.StatusBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="{DynamicResource StatusBarHeight}"
             Background="{DynamicResource AccentPrimaryBrush}">

    <DockPanel Margin="8,0" LastChildFill="False">

        <!-- LEFT: Active section breadcrumb + operation indicator -->
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Left"
                    VerticalAlignment="Center">

            <!-- Busy spinner -->
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       FontSize="11"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       Visibility="{Binding WizardVm.IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- spinning done via render transform in Shell.xaml Animations -->
                <TextBlock.Text>&#xE895;</TextBlock.Text>
            </TextBlock>

            <TextBlock VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="White">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Ready"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WizardVm.IsBusy}" Value="True">
                                <Setter Property="Text" Value="{Binding WizardVm.BusyMessage}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- RIGHT: Version + Theme toggle + section indicator -->
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Right"
                    VerticalAlignment="Center">

            <!-- Runtime status badge (only shown in Runtime section) -->
            <Border CornerRadius="3"
                    Padding="6,2"
                    Margin="0,0,8,0"
                    Visibility="{Binding IsRuntimeSection, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#20FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RuntimeVm.IsRefreshing}" Value="True">
                                <Setter Property="Background" Value="#30FFFFFF"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6"
                             VerticalAlignment="Center"
                             Margin="0,0,5,0"
                             Fill="White"
                             Opacity="0.9"/>
                    <TextBlock FontSize="11"
                               Foreground="White"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Runtime"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RuntimeVm.IsRefreshing}" Value="True">
                                        <Setter Property="Text" Value="Refreshing…"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Rectangle Width="1" Height="12" Fill="White" Opacity="0.3" Margin="0,0,8,0"/>

            <!-- Theme toggle -->
            <Button Command="{Binding ToggleThemeCommand}"
                    ToolTip="{Binding ThemeToggleLabel}"
                    Style="{StaticResource BtnIcon}"
                    Width="22" Height="22"
                    Margin="0,0,6,0">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="12"
                           Foreground="White"
                           Text="&#xE793;"/>
            </Button>

            <!-- Version badge -->
            <TextBlock Text="{Binding AppVersion}"
                       FontSize="11"
                       Foreground="White"
                       Opacity="0.75"
                       VerticalAlignment="Center"/>
        </StackPanel>

    </DockPanel>
</UserControl>
