<Window x:Class="WEDM.UI.Views.Dialogs.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About WEDM"
        Width="480" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#0d1117">
    <Border Padding="24" BorderBrush="#30363d" BorderThickness="1" CornerRadius="8" Margin="12">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border Width="44" Height="44" CornerRadius="8" Background="#238636" Margin="0,0,14,0">
                    <TextBlock Text="W" Foreground="White" FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProductName}" Foreground="#e6edf3" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DisplayVersion}" Foreground="#8b949e" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="UI host" Foreground="#8b949e" FontSize="11"/>
            <TextBlock Text="{Binding UiAssemblyFileVersion}" Foreground="#e6edf3" Margin="0,0,0,10"/>

            <TextBlock Text="Deployment engine" Foreground="#8b949e" FontSize="11"/>
            <TextBlock Text="{Binding EngineAssemblyFileVersion}" Foreground="#e6edf3" Margin="0,0,0,10"/>

            <TextBlock Text="Release channel" Foreground="#8b949e" FontSize="11"/>
            <TextBlock Text="{Binding ReleaseChannel}" Foreground="#e6edf3" Margin="0,0,0,10"/>

            <TextBlock Text="Runtime" Foreground="#8b949e" FontSize="11"/>
            <TextBlock Text="{Binding FrameworkDescription}" Foreground="#e6edf3" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <TextBlock Text="Release notes file" Foreground="#8b949e" FontSize="11"/>
            <TextBlock Text="{Binding ReleaseNotesPath}" Foreground="#58a6ff" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <TextBlock Text="Local update manifest (optional)" Foreground="#8b949e" FontSize="11"/>
            <TextBlock Text="{Binding UpdateManifestPath}" Foreground="#58a6ff" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <TextBlock Text="WebLogic Enterprise Deployment Manager automates install, patch, harden, and compliance workflows. For Oracle product documentation use the in-app documentation link."
                       Foreground="#8b949e" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <Button Content="Close" HorizontalAlignment="Right" Padding="20,6"
                    Click="Close_Click" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
        </StackPanel>
    </Border>
</Window>
