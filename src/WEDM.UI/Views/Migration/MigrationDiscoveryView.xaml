<UserControl x:Class="WEDM.UI.Views.Migration.MigrationDiscoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Migration"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:MigrationDiscoveryViewModel, IsDesignTimeCreatable=False}">

    <StackPanel>
        <Border Style="{StaticResource MigrationStatusBanner}">
            <StackPanel>
                <TextBlock Text="{Binding ScanModeDisplay, Mode=OneWay}" Style="{StaticResource TypeLabel}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ScanStatusMessage, Mode=OneWay}"
                           Style="{StaticResource TypeBody}" TextWrapping="Wrap"/>
                <ProgressBar Value="{Binding DiscoveryProgress, Mode=OneWay}" Maximum="100" Height="6"
                             Margin="0,10,0,0"
                             Visibility="{Binding ScanInProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <TextBlock Text="Environment paths" Style="{StaticResource MigrationSectionTitle}"/>
        <Border Style="{StaticResource MigrationPanelCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Middleware home" Style="{StaticResource TypeLabel}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"
                         Text="{Binding MiddlewareHome, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding ScanInProgress, Converter={StaticResource InverseBoolConverter}}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Domain home" Style="{StaticResource TypeLabel}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBoxStyle}"
                         Text="{Binding DomainHome, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding ScanInProgress, Converter={StaticResource InverseBoolConverter}}"/>
            </Grid>
        </Border>

        <Button Style="{StaticResource BtnPrimary}" Content="Run environment discovery"
                Command="{Binding RunDiscoveryCommand}" HorizontalAlignment="Left" Margin="0,0,0,20"
                IsEnabled="{Binding ScanInProgress, Converter={StaticResource InverseBoolConverter}}"/>

        <TextBlock Text="Discovery pipeline" Style="{StaticResource TypeH3}" Margin="0,0,0,8"
                   Visibility="{Binding ScanInProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <ItemsControl ItemsSource="{Binding DiscoveryStages, Mode=OneWay}" Margin="0,0,0,16"
                      Visibility="{Binding ScanInProgress, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource MigrationPanelCard}" Padding="10,8" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource TypeLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Status}" Style="{StaticResource TypeCaption}" Margin="12,0"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource TypeCaption}" HorizontalAlignment="Right">
                                <Run Text="{Binding DurationMs, Mode=OneWay}"/><Run Text=" ms"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Style="{StaticResource MigrationEmptyState}"
                Visibility="{Binding IsEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No discovery results yet" Style="{StaticResource TypeH3}" HorizontalAlignment="Center"/>
                <TextBlock Text="Start discovery to populate topology, JVM configuration, patch inventory, and Forms / Reports metadata."
                           Style="{StaticResource TypeCaption}" Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <UniformGrid Columns="3" Visibility="{Binding HasDiscoveryResults, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource MigrationPanelCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="WebLogic topology" Style="{StaticResource TypeH3}" Margin="0,0,0,12"/>
                    <TextBlock Style="{StaticResource TypeCaption}"><Run Text="Domain: "/><Run Text="{Binding Topology.DomainName, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="Managed: "/><Run Text="{Binding Topology.ManagedServerCount, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="Clusters: "/><Run Text="{Binding Topology.ClusterCount, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="SSL: "/><Run Text="{Binding Topology.SslProtocolSummary, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="Node Manager: "/><Run Text="{Binding Topology.NodeManagerType, Mode=OneWay}"/></TextBlock>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MigrationPanelCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Forms / Reports" Style="{StaticResource TypeH3}" Margin="0,0,0,12"/>
                    <TextBlock Style="{StaticResource TypeCaption}"><Run Text="Forms: "/><Run Text="{Binding FormsMetadata.FormCount, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="Reports: "/><Run Text="{Binding FormsMetadata.ReportCount, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="Modules: "/><Run Text="{Binding FormsMetadata.ModuleCount, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="WebUtil: "/><Run Text="{Binding FormsMetadata.UsesWebUtil, Mode=OneWay}"/></TextBlock>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MigrationPanelCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Oracle inventory" Style="{StaticResource TypeH3}" Margin="0,0,0,12"/>
                    <TextBlock Style="{StaticResource TypeCaption}"><Run Text="Homes: "/><Run Text="{Binding OracleInventory.HomeCount, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="Patches: "/><Run Text="{Binding PatchInventory.Count, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource TypeCaption}" Margin="0,4,0,0"><Run Text="Healthy: "/><Run Text="{Binding OracleInventory.InventoryHealthy, Mode=OneWay}"/></TextBlock>
                </StackPanel>
            </Border>
        </UniformGrid>

        <TextBlock Text="Managed servers" Style="{StaticResource TypeH3}" Margin="0,16,0,8"
                   Visibility="{Binding HasDiscoveryResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <ItemsControl ItemsSource="{Binding ManagedServers, Mode=OneWay}"
                      Visibility="{Binding HasDiscoveryResults, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource MigrationPanelCard}" Padding="12,10" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" Style="{StaticResource TypeLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Cluster}" Style="{StaticResource TypeCaption}" Margin="12,0"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource TypeCaption}">
                                <Run Text=":"/><Run Text="{Binding ListenPort, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding State, Mode=OneWay}"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Patch inventory" Style="{StaticResource TypeH3}" Margin="0,16,0,8"
                   Visibility="{Binding HasDiscoveryResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <ItemsControl ItemsSource="{Binding PatchInventory, Mode=OneWay}" MaxHeight="200"
                      Visibility="{Binding HasDiscoveryResults, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource MigrationPanelCard}" Padding="10,8" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding PatchId}" Style="{StaticResource TypeCaption}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Description}" Style="{StaticResource TypeCaption}" Margin="12,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Discovery insights" Style="{StaticResource TypeH3}" Margin="0,16,0,8"
                   Visibility="{Binding HasDiscoveryResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <ItemsControl ItemsSource="{Binding DiscoveryInsights, Mode=OneWay}"
                      Visibility="{Binding HasDiscoveryResults, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource MigrationPanelCard}" Padding="12,10" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource TypeLabel}"/>
                            <TextBlock Text="{Binding Detail}" Style="{StaticResource TypeCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Scan warnings" Style="{StaticResource TypeH3}" Margin="0,12,0,8"
                   Visibility="{Binding HasDiscoveryWarnings, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <ItemsControl ItemsSource="{Binding DiscoveryWarnings, Mode=OneWay}"
                      Visibility="{Binding HasDiscoveryWarnings, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Style="{StaticResource TypeCaption}"
                               Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Style="{StaticResource MigrationPanelCard}" Margin="0,12,0,0"
                Visibility="{Binding HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"/>
        </Border>
    </StackPanel>
</UserControl>
