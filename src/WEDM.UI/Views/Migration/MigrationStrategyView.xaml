<UserControl x:Class="WEDM.UI.Views.Migration.MigrationStrategyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Migration"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:MigrationStrategyViewModel, IsDesignTimeCreatable=False}">
    <StackPanel>
        <TextBlock Text="Migration strategy" Style="{StaticResource TypeH2}" Margin="0,0,0,16"/>
        <ComboBox Style="{StaticResource ComboBoxStyle}" Width="360" HorizontalAlignment="Left"
                  ItemsSource="{Binding StrategyOptions}"
                  SelectedItem="{Binding SelectedStrategy}"/>
        <Border CornerRadius="6" Padding="14,12" Margin="0,16,0,16"
                Background="{StaticResource BackgroundPanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
            <TextBlock Text="{Binding StrategyDescription, Mode=OneWay}"
                       Style="{StaticResource TypeBody}" TextWrapping="Wrap"/>
        </Border>
        <CheckBox Content="Enable parallel-run validation window" IsChecked="{Binding EnableParallelRunWindow}" Margin="0,0,0,8"/>
        <CheckBox Content="Generate rollback snapshot before cutover" IsChecked="{Binding GenerateRollbackSnapshot}" Margin="0,0,0,8"/>
        <CheckBox Content="Schedule automated validation gates between phases" IsChecked="{Binding ScheduleValidationGates}" Margin="0,0,0,16"/>
        <TextBlock Text="Strategy notes" Style="{StaticResource TypeLabel}" Margin="0,0,0,6"/>
        <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding StrategyNotes, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
