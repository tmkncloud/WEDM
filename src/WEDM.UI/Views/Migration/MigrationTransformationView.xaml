<UserControl x:Class="WEDM.UI.Views.Migration.MigrationTransformationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WEDM.UI.ViewModels.Migration"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:MigrationTransformationViewModel, IsDesignTimeCreatable=False}">

    <StackPanel>
        <Border Style="{StaticResource MigrationStatusBanner}">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" Style="{StaticResource TypeBody}" TextWrapping="Wrap"/>
                <ProgressBar Value="{Binding TransformProgress, Mode=OneWay}" Maximum="100" Height="6" Margin="0,10,0,0"
                             Visibility="{Binding TransformInProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <UniformGrid Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource MigrationPanelCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="Artifacts" Style="{StaticResource TypeCaption}"/>
                    <TextBlock Text="{Binding ArtifactCount, Mode=OneWay}" Style="{StaticResource TypeH3}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MigrationPanelCard}" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="Remediations" Style="{StaticResource TypeCaption}"/>
                    <TextBlock Text="{Binding RemediationCount, Mode=OneWay}" Style="{StaticResource TypeH3}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MigrationPanelCard}" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="Confidence" Style="{StaticResource TypeCaption}"/>
                    <TextBlock Text="{Binding ConfidenceDisplay, Mode=OneWay}" Style="{StaticResource TypeH3}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MigrationPanelCard}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="Workspace" Style="{StaticResource TypeCaption}"/>
                    <TextBlock Text="Open folder" Style="{StaticResource TypeLabel}" Foreground="{StaticResource AccentPrimaryBrush}"
                               Cursor="Hand" MouseLeftButtonUp="OpenWorkspace_Click"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Style="{StaticResource BtnPrimary}" Content="Generate migration artifacts"
                    Command="{Binding RunTransformationCommand}" Margin="0,0,8,0"
                    IsEnabled="{Binding TransformInProgress, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Style="{StaticResource BtnSecondary}" Content="Open workspace"
                    Command="{Binding OpenWorkspaceCommand}"/>
        </StackPanel>

        <Border Style="{StaticResource MigrationEmptyState}"
                Visibility="{Binding IsEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Run transformation to generate WLST scripts, config modernizations, remediation plans, and migration workspace."
                       Style="{StaticResource TypeCaption}" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>

        <TextBlock Text="Transformation pipeline" Style="{StaticResource TypeH3}" Margin="0,0,0,8"
                   Visibility="{Binding TransformInProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <ItemsControl ItemsSource="{Binding TransformationStages, Mode=OneWay}" Margin="0,0,0,12"
                      Visibility="{Binding TransformInProgress, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource MigrationPanelCard}" Padding="8,6" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource TypeLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Status}" Style="{StaticResource TypeCaption}" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <UniformGrid Columns="2" Visibility="{Binding HasTransformation, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource MigrationPanelCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Forms modernization" Style="{StaticResource TypeH3}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding FormsModernizationSummary, Mode=OneWay}" Style="{StaticResource TypeCaption}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MigrationPanelCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Reports modernization" Style="{StaticResource TypeH3}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ReportsModernizationSummary, Mode=OneWay}" Style="{StaticResource TypeCaption}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <TextBlock Text="Generated artifacts" Style="{StaticResource TypeH3}" Margin="0,16,0,8"
                   Visibility="{Binding HasTransformation, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <ListBox ItemsSource="{Binding Artifacts, Mode=OneWay}" MaxHeight="140" Margin="0,0,0,8"
                 Visibility="{Binding HasTransformation, Converter={StaticResource BoolToVisibilityConverter}}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource BtnGhost}" Content="{Binding DisplayName}"
                            Command="{Binding DataContext.PreviewArtifactCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Style="{StaticResource MigrationPanelCard}" MaxHeight="220" Margin="0,0,0,12"
                Visibility="{Binding HasTransformation, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding SelectedArtifactPreview, Mode=OneWay}" FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}"/>
            </ScrollViewer>
        </Border>

        <TextBlock Text="Remediation recommendations" Style="{StaticResource TypeH3}" Margin="0,0,0,8"
                   Visibility="{Binding HasTransformation, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <ItemsControl ItemsSource="{Binding Remediations, Mode=OneWay}" MaxHeight="160"
                      Visibility="{Binding HasTransformation, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource MigrationPanelCard}" Padding="10,8" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource TypeLabel}"/>
                            <TextBlock Text="{Binding Detail}" Style="{StaticResource TypeCaption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
