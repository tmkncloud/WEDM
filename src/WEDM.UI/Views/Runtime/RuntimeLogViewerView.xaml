<UserControl x:Class="WEDM.UI.Views.Runtime.RuntimeLogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rvm="clr-namespace:WEDM.UI.ViewModels.Runtime"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=rvm:LogViewerViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>   <!-- Filter / control toolbar -->
            <RowDefinition Height="*"/>    <!-- Log lines list           -->
            <RowDefinition Height="24"/>   <!-- Status bar               -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             FILTER / CONTROL TOOLBAR
             ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search / filter box -->
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource RuntimeFilterBoxStyle}"
                             VerticalContentAlignment="Center"
                             Padding="26,4,8,4"/>
                    <!-- Search icon -->
                    <TextBlock Text="🔍" FontSize="11"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">

                    <!-- Pause/Resume -->
                    <Button Style="{DynamicResource RuntimeToolbarButtonStyle}"
                            Command="{Binding TogglePauseCommand}"
                            ToolTip="Pause or resume live tailing">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="⏸ Pause"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                <Setter Property="Text" Value="▶ Resume"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>

                    <!-- Clear -->
                    <Button Style="{DynamicResource RuntimeToolbarButtonStyle}"
                            Command="{Binding ClearCommand}"
                            Content="✕ Clear"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             LOG LINES — VIRTUALIZED LIST
             ══════════════════════════════════════════════════════════════════ -->
        <ListBox x:Name="LogListBox"
                 Grid.Row="1"
                 ItemsSource="{Binding LogLines}"
                 Style="{DynamicResource RuntimeLogViewerListBoxStyle}"
                 HorizontalContentAlignment="Stretch"
                 SelectionMode="Extended">

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type rvm:LogLineViewModel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Timestamp -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding TimeLabel}"
                                   Style="{DynamicResource RuntimeLogTimestampStyle}"/>

                        <!-- Log line text -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Line}"
                                   Style="{DynamicResource RuntimeLogLineTextStyle}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource RuntimeLogLineTextStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <!-- Empty state -->
            <ListBox.Template>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{DynamicResource BackgroundCanvasBrush}">
                        <Grid>
                            <ScrollViewer x:Name="PART_ScrollViewer"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Auto">
                                <ItemsPresenter/>
                            </ScrollViewer>
                            <TextBlock Text="No log lines — start tail to stream the log file."
                                       Style="{DynamicResource RuntimeEmptyStateStyle}"
                                       Visibility="{Binding LogLines.Count, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=hide_when_value}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RuntimeEmptyStateStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LogLines.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </ListBox.Template>
        </ListBox>

        <!-- ══════════════════════════════════════════════════════════════════
             STATUS BAR
             ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource BackgroundElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status text -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Tailing indicator -->
                    <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTailing}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Line count + source -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding TotalLines, Mode=OneWay}"/>
                        <Run Text=" lines"/>
                    </TextBlock>
                    <TextBlock Text=" · " FontSize="11" Foreground="{DynamicResource BorderSubtleBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SourceLabel}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               MaxWidth="200"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
