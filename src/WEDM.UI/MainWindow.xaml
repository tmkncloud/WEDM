<Window x:Class="WEDM.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WEDM.UI.ViewModels"
        xmlns:wvm="clr-namespace:WEDM.UI.ViewModels.Wizard"
        xmlns:mvm="clr-namespace:WEDM.UI.ViewModels.Migration"
        xmlns:dvm="clr-namespace:WEDM.UI.ViewModels.Decommission"
        xmlns:rvm="clr-namespace:WEDM.UI.ViewModels.Runtime"
        xmlns:wviews="clr-namespace:WEDM.UI.Views.Wizard"
        xmlns:mviews="clr-namespace:WEDM.UI.Views.Migration"
        xmlns:dviews="clr-namespace:WEDM.UI.Views.Decommission"
        xmlns:rviews="clr-namespace:WEDM.UI.Views.Runtime"
        xmlns:shell="clr-namespace:WEDM.UI.Views.Shell"
        mc:Ignorable="d"
        Title="WebLogic Enterprise Deployment Manager"
        Height="800" Width="1340"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundCanvasBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        d:DataContext="{d:DesignInstance Type=vm:AppShellViewModel}">

    <Window.Resources>

        <!-- ══════════════════════════════════════════════════════════════════
             SHELL CONTENT ROUTING
             MainWindowViewModel   → WizardShellView
             RuntimeDashboardViewModel → RuntimeDashboardView
             ══════════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type vm:MainWindowViewModel}">
            <wviews:WizardShellView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type rvm:RuntimeDashboardViewModel}">
            <rviews:RuntimeDashboardView DataContext="{Binding}"/>
        </DataTemplate>

        <!-- ══════════════════════════════════════════════════════════════════
             WIZARD STEP DataTemplates  (all 25 steps preserved)
             ══════════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type wvm:OperationSelectionViewModel}">
            <wviews:OperationSelectionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:WelcomeViewModel}">
            <wviews:WelcomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:ProductSystemHealthViewModel}">
            <wviews:ProductSystemHealthView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:VersionSelectionViewModel}">
            <wviews:VersionSelectionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:PathConfigViewModel}">
            <wviews:PathConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:DatabaseConfigViewModel}">
            <wviews:DatabaseConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:DomainConfigViewModel}">
            <wviews:DomainConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:PatchManagementViewModel}">
            <wviews:PatchManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:SecurityComplianceViewModel}">
            <wviews:SecurityComplianceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:PrerequisiteViewModel}">
            <wviews:PrerequisiteView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:DeploymentSummaryViewModel}">
            <wviews:DeploymentSummaryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:DeploymentProgressViewModel}">
            <wviews:DeploymentProgressView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationSourceVersionViewModel}">
            <mviews:MigrationSourceVersionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationTargetVersionViewModel}">
            <mviews:MigrationTargetVersionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationDiscoveryViewModel}">
            <mviews:MigrationDiscoveryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationCompatibilityViewModel}">
            <mviews:MigrationCompatibilityView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationStrategyViewModel}">
            <mviews:MigrationStrategyView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationValidationViewModel}">
            <mviews:MigrationValidationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationTransformationViewModel}">
            <mviews:MigrationTransformationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationSummaryViewModel}">
            <mviews:MigrationSummaryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mvm:MigrationExecutionViewModel}">
            <mviews:MigrationExecutionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type dvm:DecommissionScopeViewModel}">
            <dviews:DecommissionScopeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type dvm:DecommissionDiscoveryViewModel}">
            <dviews:DecommissionDiscoveryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type dvm:DecommissionPreviewViewModel}">
            <dviews:DecommissionPreviewView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type dvm:DecommissionSummaryViewModel}">
            <dviews:DecommissionSummaryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type dvm:DecommissionProgressViewModel}">
            <dviews:DecommissionProgressView/>
        </DataTemplate>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════
         ROOT LAYOUT: 3 rows — TitleBar / Shell body / StatusBar
         ══════════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>   <!-- [0] Title bar  -->
            <RowDefinition Height="*"/>                                   <!-- [1] Shell body -->
            <RowDefinition Height="24"/>  <!-- [2] Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             [0] TITLE BAR — 36px compact chrome
             ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Logo + name -->
                    <ColumnDefinition Width="*"/>      <!-- Drag region -->
                    <ColumnDefinition Width="Auto"/>  <!-- Controls -->
                </Grid.ColumnDefinitions>

                <!-- Logo badge + product name -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Border Width="22" Height="22"
                            CornerRadius="4"
                            Background="{DynamicResource AccentPrimaryBrush}"
                            Margin="0,0,8,0">
                        <TextBlock Text="W"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="WEDM"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Border CornerRadius="3"
                            Padding="5,1"
                            Margin="6,0,0,0"
                            Background="{DynamicResource AccentSubtleBrush}"
                            BorderBrush="{DynamicResource AccentBorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding AppVersion}"
                                   FontSize="10"
                                   Foreground="{DynamicResource AccentPrimaryBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Centre drag region (double-click to maximise) -->
                <Rectangle Grid.Column="1"
                            Fill="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

                <!-- Window controls + actions -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">

                    <!-- Section label -->
                    <TextBlock Text="{Binding SectionPanelTitle}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <!-- Help -->
                    <Button Command="{Binding OpenHelpCommand}"
                            Style="{StaticResource WindowChromeBtn}"
                            ToolTip="Oracle Documentation"
                            Width="32" Height="32">
                        <TextBlock Text="&#xE897;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </Button>

                    <!-- About -->
                    <Button Command="{Binding ShowAboutCommand}"
                            Style="{StaticResource WindowChromeBtn}"
                            ToolTip="About WEDM"
                            Width="32" Height="32">
                        <TextBlock Text="&#xE946;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </Button>

                    <Rectangle Width="1" Height="14"
                               Fill="{DynamicResource BorderSubtleBrush}"
                               Margin="4,0"/>

                    <!-- Minimize -->
                    <Button Style="{StaticResource WindowChromeBtn}"
                            Click="MinimizeWindow_Click"
                            ToolTip="Minimize"
                            Width="36" Height="{DynamicResource TitleBarHeight}">
                        <TextBlock Text="&#xE921;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                    <!-- Maximise / restore -->
                    <Button Style="{StaticResource WindowChromeBtn}"
                            Click="MaximizeWindow_Click"
                            ToolTip="Maximize"
                            Width="36" Height="{DynamicResource TitleBarHeight}">
                        <TextBlock Text="&#xE922;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                    <!-- Close -->
                    <Button Style="{StaticResource WindowCloseChromeBtn}"
                            Click="CloseWindow_Click"
                            ToolTip="Close"
                            Width="36" Height="{DynamicResource TitleBarHeight}">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             [1] SHELL BODY — ActivityBar | SectionPanel | ContentHost
             ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- [0] ActivityBar — fixed 48px -->
                <ColumnDefinition Width="Auto"/>
                <!-- [1] SectionPanel — 220px or collapsed -->
                <ColumnDefinition Width="Auto"/>
                <!-- [2] Content host — fills remainder -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── ActivityBar ──────────────────────────────────────────── -->
            <shell:ActivityBarView Grid.Column="0"
                                   DataContext="{Binding}"/>

            <!-- ── SectionPanel (collapsible) ───────────────────────────── -->
            <shell:SectionPanelView Grid.Column="1"
                                    DataContext="{Binding}">
                <shell:SectionPanelView.Style>
                    <Style TargetType="shell:SectionPanelView">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSectionPanelVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </shell:SectionPanelView.Style>
            </shell:SectionPanelView>

            <!-- ── Content host ─────────────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- Section placeholder for Dashboard / Discovery / etc.
                     Shown when no routed content is set (null ActiveContent). -->
                <Border Background="{DynamicResource BackgroundCanvasBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveContent}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SectionPanelTitle}"
                                   FontSize="22"
                                   FontWeight="Light"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Section coming soon"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Active routed content (wizard or runtime) -->
                <ContentPresenter Content="{Binding ActiveContent}"/>

            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             [2] STATUS BAR — 24px operational bar
             ══════════════════════════════════════════════════════════════════ -->
        <shell:StatusBarView Grid.Row="2"
                             DataContext="{Binding}"/>

    </Grid>
</Window>
