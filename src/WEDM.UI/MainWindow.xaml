<Window x:Class="WEDM.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WEDM.UI.ViewModels"
        xmlns:wvm="clr-namespace:WEDM.UI.ViewModels.Wizard"
        xmlns:wviews="clr-namespace:WEDM.UI.Views.Wizard"
        xmlns:converters="clr-namespace:WEDM.UI.Converters"
        mc:Ignorable="d"
        Title="WebLogic Enterprise Deployment Manager"
        Height="780" Width="1280"
        MinHeight="680" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDeepBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}">

    <Window.Resources>
        <!-- DataTemplate selectors for wizard steps -->
        <DataTemplate DataType="{x:Type wvm:WelcomeViewModel}">
            <wviews:WelcomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:ProductSystemHealthViewModel}">
            <wviews:ProductSystemHealthView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:VersionSelectionViewModel}">
            <wviews:VersionSelectionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:PathConfigViewModel}">
            <wviews:PathConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:DatabaseConfigViewModel}">
            <wviews:DatabaseConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:DomainConfigViewModel}">
            <wviews:DomainConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:PatchManagementViewModel}">
            <wviews:PatchManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:SecurityComplianceViewModel}">
            <wviews:SecurityComplianceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:PrerequisiteViewModel}">
            <wviews:PrerequisiteView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:DeploymentSummaryViewModel}">
            <wviews:DeploymentSummaryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:DeploymentProgressViewModel}">
            <wviews:DeploymentProgressView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>    <!-- Title bar -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="44"/>    <!-- Footer nav bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════
             TITLE BAR (custom, draggable)
             ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradientBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <!-- Oracle/WebLogic logo mark -->
                    <Border Width="28" Height="28" CornerRadius="6"
                            Background="{StaticResource AccentGradientBrush}"
                            Margin="0,0,10,0">
                        <TextBlock Text="W" Foreground="White"
                                   FontFamily="Segoe UI Semibold" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="WebLogic Enterprise Deployment Manager"
                               Style="{StaticResource TypeH3}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Border Background="{StaticResource AccentSubtleBrush}"
                            BorderBrush="{StaticResource AccentPrimaryBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="6,2" Margin="10,0,0,0">
                        <TextBlock Text="{Binding AppVersion}"
                                   Style="{StaticResource TypeBadge}"
                                   Foreground="{StaticResource AccentPrimaryBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Environment badge (center) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="ENTERPRISE MIDDLEWARE AUTOMATION"
                               Style="{StaticResource TypeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                    <Border Background="{StaticResource BackgroundElevatedBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource TypeCaption}"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Release "/>
                            <Run Text="{Binding ReleaseChannelDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Style="{StaticResource BtnIcon}"
                            Click="MinimizeWindow_Click"
                            ToolTip="Minimize">
                        <TextBlock Text="─" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                    </Button>
                    <Button Style="{StaticResource BtnIcon}"
                            Click="MaximizeWindow_Click"
                            ToolTip="Maximize/Restore">
                        <TextBlock Text="□" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                    </Button>
                    <Button Style="{StaticResource BtnIcon}"
                            Click="CloseWindow_Click"
                            ToolTip="Close">
                        <TextBlock Text="✕" Foreground="{StaticResource DangerBrush}" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             MAIN CONTENT AREA
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>  <!-- Sidebar -->
                <ColumnDefinition Width="*"/>    <!-- Content panel -->
            </Grid.ColumnDefinitions>

            <!-- ─── SIDEBAR ──────────────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarGradientBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- Sidebar Header -->
                    <Border DockPanel.Dock="Top"
                            Padding="20,20,20,12"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="INSTALLATION STEPS"
                                       Style="{StaticResource TypeH3}"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource TypeCaption}">
                                    <Run Text="{Binding CurrentStepIndex, StringFormat={}{0}}"/>
                                    <Run Text=" of "/>
                                    <Run Text="{Binding Steps.Count, StringFormat={}{0}}"/>
                                </TextBlock>
                                <TextBlock Text=" steps" Style="{StaticResource TypeCaption}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Step List -->
                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Steps}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.NavigateToCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding StepIndex}"
                                            Style="{StaticResource BtnGhost}"
                                            HorizontalContentAlignment="Stretch"
                                            Height="Auto" Padding="0">
                                        <Border x:Name="stepBorder"
                                                Padding="16,10" Margin="8,2"
                                                CornerRadius="6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="32"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Step indicator circle -->
                                                <Border Grid.Column="0"
                                                        Width="24" Height="24"
                                                        CornerRadius="12"
                                                        HorizontalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BackgroundElevatedBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource SuccessSubtleBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock x:Name="stepIcon"
                                                               Text="{Binding StepIndex, StringFormat={}{0}}"
                                                               FontSize="11" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="Text" Value="✔"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Step text -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StepTitle}"
                                                               FontSize="13" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding StepDescription}"
                                                               FontSize="10.5"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="160"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Sidebar Footer -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="16,12"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="Oracle Middleware" Style="{StaticResource TypeCaption}"/>
                            <TextBlock Text="Enterprise Deployment Suite" Style="{StaticResource TypeCaption}"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ─── CONTENT PANEL ─────────────────────────────────────────────── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>    <!-- Step header -->
                    <RowDefinition Height="*"/>       <!-- Step content -->
                    <RowDefinition Height="Auto"/>    <!-- Overall progress bar -->
                </Grid.RowDefinitions>

                <!-- Step header banner -->
                <Border Grid.Row="0"
                        Background="{StaticResource BackgroundPanelBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="32,20,32,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding CurrentStep.StepTitle}"
                                       Style="{StaticResource TypeH1}"/>
                            <TextBlock Text="{Binding CurrentStep.StepDescription}"
                                       Style="{StaticResource TypeBody}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <!-- Step icon -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentStep.StepIcon}"
                                   FontSize="36"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                    </Grid>
                </Border>

                <!-- Step content (data-template driven) -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0">
                    <ContentControl Content="{Binding CurrentStep}">
                        <ContentControl.RenderTransform>
                            <TranslateTransform x:Name="ContentTranslate"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                </ScrollViewer>

                <!-- Overall progress indicator -->
                <Border Grid.Row="2"
                        Background="{StaticResource BackgroundElevatedBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,1,0,0"
                        Height="4">
                    <Grid>
                        <Rectangle Fill="{StaticResource AccentGradientBrush}" HorizontalAlignment="Left">
                            <Rectangle.Width>
                                <MultiBinding>
                                    <MultiBinding.Converter>
                                        <converters:PercentToWidthMultiConverter/>
                                    </MultiBinding.Converter>
                                    <Binding Path="ProgressPercent"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                </MultiBinding>
                            </Rectangle.Width>
                        </Rectangle>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════
             FOOTER NAVIGATION BAR
             ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundPanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Help link -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnGhost}"
                            Command="{Binding OpenHelpCommand}"
                            Content="📘  Oracle Documentation"
                            Height="32" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource BtnGhost}"
                            Command="{Binding ShowAboutCommand}"
                            Content="About WEDM"
                            Height="32"/>
                </StackPanel>

                <!-- Right: Back / Next navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnSecondary}"
                            Command="{Binding BackCommand}"
                            Content="← Back"
                            Width="100"
                            Margin="0,0,8,0"/>
                    <Button Command="{Binding NextCommand}"
                            Width="140"
                            Height="36">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                                <Setter Property="Content" Value="Next →"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDeploymentReadyStep}" Value="True">
                                        <Setter Property="Content" Value="🚀  Deploy"/>
                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                                        <Setter Property="Content" Value="Finish"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Global Busy Overlay ──────────────────────────────────────────── -->
        <Grid Grid.RowSpan="3"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#80000000">
            <Border Background="{StaticResource BackgroundCardBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="12"
                    Padding="40,32"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="320">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⟳" FontSize="36"
                               Foreground="{StaticResource AccentPrimaryBrush}"
                               HorizontalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" CenterX="18" CenterY="18"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="{Binding BusyMessage}"
                               Style="{StaticResource TypeBody}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
