<Window x:Class="WEDM.UI.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Width="420" Height="240"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="12" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Border Width="48" Height="48" CornerRadius="10" Background="#238636" Margin="0,0,14,0">
                        <TextBlock Text="W" Foreground="White" FontSize="26" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="ProductTitle" Text="WEDM" Foreground="#e6edf3" FontSize="22" FontWeight="SemiBold"/>
                        <TextBlock x:Name="VersionLine" Foreground="#8b949e" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="Enterprise middleware lifecycle &amp; security"
                           Foreground="#8b949e" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Text="Starting…" Foreground="#484f58" FontSize="11" HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
