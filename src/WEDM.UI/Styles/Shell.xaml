<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         WEDM Shell Style System
         ActivityBar, SectionPanel, StatusBar, TitleBar, NavItem styles.
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- ── TitleBar ────────────────────────────────────────────────────────── -->
    <Style x:Key="TitleBarStyle" TargetType="Border">
        <Setter Property="Height"          Value="36"/>
        <Setter Property="Background"      Value="{DynamicResource BackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- ── ActivityBar ─────────────────────────────────────────────────────── -->
    <Style x:Key="ActivityBarStyle" TargetType="Border">
        <Setter Property="Width"           Value="48"/>
        <Setter Property="Background"      Value="{DynamicResource BackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <!-- ── SectionPanel ────────────────────────────────────────────────────── -->
    <Style x:Key="SectionPanelStyle" TargetType="Border">
        <Setter Property="Width"           Value="220"/>
        <Setter Property="Background"      Value="{DynamicResource BackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <!-- Section panel header area -->
    <Style x:Key="SectionHeaderStyle" TargetType="Border">
        <Setter Property="Padding"         Value="12,10"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- ── StatusBar ───────────────────────────────────────────────────────── -->
    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Height"          Value="24"/>
        <Setter Property="Background"      Value="{DynamicResource BackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <!-- ── Navigation Item (SectionPanel row) ──────────────────────────────── -->
    <Style x:Key="NavItemButtonStyle" TargetType="Button">
        <Setter Property="Height"                     Value="32"/>
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Padding"                    Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="root"
                            Background="{TemplateBinding Background}"
                            BorderThickness="2,0,0,0"
                            BorderBrush="Transparent">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="root" Property="Background" Value="{DynamicResource BackgroundHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="root" Property="Background" Value="{DynamicResource AccentSubtleBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Active nav item gets accent left-border and highlighted text -->
    <Style x:Key="NavItemButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavItemButtonStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="root"
                            Background="{DynamicResource BackgroundHoverBrush}"
                            BorderThickness="2,0,0,0"
                            BorderBrush="{DynamicResource AccentPrimaryBrush}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Window chrome button (min/max/close) ────────────────────────────── -->
    <Style x:Key="WindowChromeBtn" TargetType="Button">
        <Setter Property="Width"           Value="32"/>
        <Setter Property="Height"          Value="32"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource BackgroundHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Close button variant — hover red -->
    <Style x:Key="WindowCloseChromeBtn" TargetType="Button" BasedOn="{StaticResource WindowChromeBtn}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource DangerBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── State Badge ─────────────────────────────────────────────────────── -->
    <Style x:Key="StateBadgeRunning" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource SuccessSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource SuccessBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="7,2"/>
    </Style>

    <Style x:Key="StateBadgeStopped" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource BackgroundElevatedBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="7,2"/>
    </Style>

    <Style x:Key="StateBadgeWarning" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource WarningSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource WarningBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="7,2"/>
    </Style>

    <Style x:Key="StateBadgeDanger" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource DangerSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource DangerBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="7,2"/>
    </Style>

    <!-- ── Card variants ───────────────────────────────────────────────────── -->
    <Style x:Key="CardFlat" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource BackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="14,12"/>
    </Style>

    <Style x:Key="CardElevated" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource BackgroundElevatedBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="14,12"/>
    </Style>

    <Style x:Key="CardSuccess" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource SuccessSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource SuccessBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="14,12"/>
    </Style>

    <Style x:Key="CardWarning" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource WarningSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource WarningBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="14,12"/>
    </Style>

    <Style x:Key="CardDanger" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource DangerSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource DangerBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="14,12"/>
    </Style>

    <Style x:Key="CardInfo" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource InfoSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource InfoBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="14,12"/>
    </Style>

    <!-- 48×48 square icon-only button for the ActivityBar -->
    <Style x:Key="ActivityBarButtonStyle" TargetType="Button">
        <Setter Property="Width"                    Value="{DynamicResource ActivityBarWidth}"/>
        <Setter Property="Height"                   Value="{DynamicResource ActivityBarWidth}"/>
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource BackgroundHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource BackgroundOverlayBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>
