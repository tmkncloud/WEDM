<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         WEDM Enterprise Dark Theme — Color Palette
         Inspired by GitHub Dark, Azure Portal, and VS Code dark themes.
         Provides consistent branding across all wizard screens.
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <Color x:Key="BackgroundDeepColor">#0D1117</Color>
    <Color x:Key="BackgroundPanelColor">#161B22</Color>
    <Color x:Key="BackgroundCardColor">#1C2128</Color>
    <Color x:Key="BackgroundElevatedColor">#21262D</Color>
    <Color x:Key="BackgroundHoverColor">#262C36</Color>

    <!-- Borders -->
    <Color x:Key="BorderSubtleColor">#21262D</Color>
    <Color x:Key="BorderDefaultColor">#30363D</Color>
    <Color x:Key="BorderMutedColor">#3D444D</Color>

    <!-- Accent — Electric Blue (Oracle brand-adjacent) -->
    <Color x:Key="AccentPrimaryColor">#2F81F7</Color>
    <Color x:Key="AccentPrimaryHoverColor">#388BFD</Color>
    <Color x:Key="AccentPrimaryActiveColor">#1F6FEB</Color>
    <Color x:Key="AccentSubtleColor">#1F2D3F</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E6EDF3</Color>
    <Color x:Key="TextSecondaryColor">#8B949E</Color>
    <Color x:Key="TextMutedColor">#6E7681</Color>
    <Color x:Key="TextLinkColor">#58A6FF</Color>

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#3FB950</Color>
    <Color x:Key="SuccessSubtleColor">#1A2E1A</Color>
    <Color x:Key="WarningColor">#D29922</Color>
    <Color x:Key="WarningSubtleColor">#2D2007</Color>
    <Color x:Key="DangerColor">#F85149</Color>
    <Color x:Key="DangerSubtleColor">#2D0F0E</Color>
    <Color x:Key="InfoColor">#58A6FF</Color>
    <Color x:Key="PurpleColor">#A371F7</Color>

    <!-- Sidebar step states -->
    <Color x:Key="StepActiveColor">#2F81F7</Color>
    <Color x:Key="StepCompletedColor">#3FB950</Color>
    <Color x:Key="StepPendingColor">#3D444D</Color>
    <Color x:Key="StepErrorColor">#F85149</Color>

    <!-- ── Brushes ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BackgroundDeepBrush"      Color="{StaticResource BackgroundDeepColor}"/>
    <SolidColorBrush x:Key="BackgroundPanelBrush"     Color="{StaticResource BackgroundPanelColor}"/>
    <SolidColorBrush x:Key="BackgroundCardBrush"      Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="BackgroundElevatedBrush"  Color="{StaticResource BackgroundElevatedColor}"/>
    <SolidColorBrush x:Key="BackgroundHoverBrush"     Color="{StaticResource BackgroundHoverColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"        Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderDefaultBrush"       Color="{StaticResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="BorderMutedBrush"         Color="{StaticResource BorderMutedColor}"/>
    <SolidColorBrush x:Key="AccentPrimaryBrush"       Color="{StaticResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentPrimaryHoverBrush"  Color="{StaticResource AccentPrimaryHoverColor}"/>
    <SolidColorBrush x:Key="AccentSubtleBrush"        Color="{StaticResource AccentSubtleColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"         Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"       Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"           Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextLinkBrush"            Color="{StaticResource TextLinkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"             Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessSubtleBrush"       Color="{StaticResource SuccessSubtleColor}"/>
    <SolidColorBrush x:Key="WarningBrush"             Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningSubtleBrush"       Color="{StaticResource WarningSubtleColor}"/>
    <SolidColorBrush x:Key="DangerBrush"              Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerSubtleBrush"        Color="{StaticResource DangerSubtleColor}"/>
    <SolidColorBrush x:Key="InfoBrush"                Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="PurpleBrush"              Color="{StaticResource PurpleColor}"/>
    <SolidColorBrush x:Key="TransparentBrush"         Color="Transparent"/>

    <!-- ── Gradient Brushes ────────────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2F81F7" Offset="0"/>
        <GradientStop Color="#A371F7" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D1117" Offset="0"/>
        <GradientStop Color="#161B22" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0D1117" Offset="0"/>
        <GradientStop Color="#1C2128" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
