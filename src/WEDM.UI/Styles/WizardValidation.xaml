<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Validation error text (FIXED: DynamicResource so it responds to theme switch) -->
    <Style x:Key="ValidationErrorText" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="Foreground"  Value="{DynamicResource DangerBrush}"/>
        <Setter Property="Margin"      Value="0,4,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Validation summary banner -->
    <Style x:Key="ValidationSummaryBorder" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource DangerSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource DangerBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="5"/>
        <Setter Property="Padding"          Value="12,8"/>
        <Setter Property="Margin"           Value="0,0,0,8"/>
    </Style>

    <!-- Success summary banner -->
    <Style x:Key="ValidationSuccessBorder" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource SuccessSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource SuccessBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="5"/>
        <Setter Property="Padding"          Value="12,8"/>
        <Setter Property="Margin"           Value="0,0,0,8"/>
    </Style>

    <!-- Warning summary banner -->
    <Style x:Key="ValidationWarningBorder" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource WarningSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource WarningBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="5"/>
        <Setter Property="Padding"          Value="12,8"/>
        <Setter Property="Margin"           Value="0,0,0,8"/>
    </Style>

    <!-- Info summary banner -->
    <Style x:Key="ValidationInfoBorder" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource InfoSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource InfoBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="5"/>
        <Setter Property="Padding"          Value="12,8"/>
        <Setter Property="Margin"           Value="0,0,0,8"/>
    </Style>

</ResourceDictionary>
