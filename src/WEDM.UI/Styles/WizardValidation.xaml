<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="ValidationErrorText" TargetType="TextBlock" BasedOn="{StaticResource TypeCaption}">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Margin" Value="0,4,0,10"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ValidationSummaryBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DangerSubtleBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

</ResourceDictionary>
