<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         WEDM Typography System
         Font: Segoe UI (universal Windows — enterprise readable)
         Scale follows Material Design-inspired type scale
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Global text override -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily"    Value="Segoe UI"/>
        <Setter Property="FontSize"      Value="13"/>
        <Setter Property="Foreground"    Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="TextWrapping"  Value="NoWrap"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <!-- Display — large hero/splash text -->
    <Style x:Key="TypeDisplay" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"    Value="22"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="LineHeight"  Value="28"/>
    </Style>

    <Style x:Key="TypeH1" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"    Value="18"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="TypeH2" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="15"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <!-- Heading 3 — card headers -->
    <Style x:Key="TypeH3" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="14"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- Body — standard content text -->
    <Style x:Key="TypeBody" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="LineHeight"  Value="20"/>
    </Style>

    <!-- Caption — small helper text, labels -->
    <Style x:Key="TypeCaption" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- Inline caption for Run/Span inside TextBlock (do not apply TextBlock styles to Run) -->
    <Style x:Key="TypeCaptionRun" TargetType="Run">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- Mono — log output, paths, commands -->
    <Style x:Key="TypeMono" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Cascadia Code, Consolas, Courier New"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="LineHeight"  Value="18"/>
    </Style>

    <!-- Label — form field labels -->
    <Style x:Key="TypeLabel" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin"      Value="0,0,0,4"/>
    </Style>

    <!-- Accent — highlighted/branded text -->
    <Style x:Key="TypeAccent" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{StaticResource AccentPrimaryBrush}"/>
    </Style>

    <!-- Version badge text -->
    <Style x:Key="TypeBadge" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Padding"     Value="6,2"/>
    </Style>
</ResourceDictionary>
