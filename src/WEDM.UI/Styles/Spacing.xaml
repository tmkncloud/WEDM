<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════════════════
         WEDM Spacing System — multiples of 4px
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Scalar spacing values -->
    <sys:Double x:Key="SpaceXs">4</sys:Double>
    <sys:Double x:Key="SpaceSm">8</sys:Double>
    <sys:Double x:Key="SpaceMd">12</sys:Double>
    <sys:Double x:Key="SpaceLg">16</sys:Double>
    <sys:Double x:Key="SpaceXl">20</sys:Double>
    <sys:Double x:Key="Space2Xl">24</sys:Double>
    <sys:Double x:Key="Space3Xl">32</sys:Double>

    <!-- Chrome measurements -->
    <sys:Double x:Key="ActivityBarWidth">48</sys:Double>
    <sys:Double x:Key="SectionPanelWidth">220</sys:Double>
    <sys:Double x:Key="TitleBarHeight">36</sys:Double>
    <sys:Double x:Key="StatusBarHeight">24</sys:Double>
    <sys:Double x:Key="ActionBarHeight">48</sys:Double>

    <!-- Component sizes -->
    <sys:Double x:Key="NavItemHeight">32</sys:Double>
    <sys:Double x:Key="InputHeight">32</sys:Double>
    <sys:Double x:Key="ButtonHeight">32</sys:Double>
    <sys:Double x:Key="DataGridRowHeight">34</sys:Double>

    <!-- Thickness constants -->
    <Thickness x:Key="PadXs">4</Thickness>
    <Thickness x:Key="PadSm">8</Thickness>
    <Thickness x:Key="PadMd">12</Thickness>
    <Thickness x:Key="PadLg">16</Thickness>
    <Thickness x:Key="PadCard">14,12</Thickness>
    <Thickness x:Key="PadCardCompact">10,8</Thickness>

    <!-- CornerRadius constants -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">6</CornerRadius>
    <CornerRadius x:Key="RadiusLg">8</CornerRadius>

</ResourceDictionary>
