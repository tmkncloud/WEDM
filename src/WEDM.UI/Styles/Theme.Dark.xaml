<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════════════
       WEDM Dark Theme — Enterprise Token System v2
       5-level surface stack for VS Code / Azure Portal visual hierarchy.
       All existing brush names kept as aliases so views compile unchanged.
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- ── Background Surface Stack ──────────────────────────────────────── -->
  <Color x:Key="BackgroundCanvasColor">#1E1E1E</Color>
  <Color x:Key="BackgroundSurfaceColor">#252526</Color>
  <Color x:Key="BackgroundElevatedColor">#2D2D30</Color>
  <Color x:Key="BackgroundOverlayColor">#333337</Color>
  <Color x:Key="BackgroundHoverColor">#3E3E42</Color>

  <!-- Legacy aliases — keep existing views working without changes -->
  <Color x:Key="BackgroundDeepColor">#1E1E1E</Color>
  <Color x:Key="BackgroundPanelColor">#252526</Color>
  <Color x:Key="BackgroundCardColor">#2D2D30</Color>
  <Color x:Key="InputFieldColor">#2D2D30</Color>

  <!-- ── Border Stack ──────────────────────────────────────────────────── -->
  <Color x:Key="BorderSubtleColor">#3C3C3C</Color>
  <Color x:Key="BorderDefaultColor">#4E4E52</Color>
  <Color x:Key="BorderMutedColor">#6B6B6E</Color>
  <Color x:Key="BorderStrongColor">#6B6B6E</Color>

  <!-- ── Text Stack ────────────────────────────────────────────────────── -->
  <Color x:Key="TextPrimaryColor">#D4D4D4</Color>
  <Color x:Key="TextSecondaryColor">#A0A0A0</Color>
  <Color x:Key="TextMutedColor">#717171</Color>
  <Color x:Key="TextDisabledColor">#4E4E52</Color>
  <Color x:Key="TextLinkColor">#58A6FF</Color>

  <!-- ── Accent ────────────────────────────────────────────────────────── -->
  <Color x:Key="AccentPrimaryColor">#2F81F7</Color>
  <Color x:Key="AccentPrimaryHoverColor">#58A6FF</Color>
  <Color x:Key="AccentPrimaryActiveColor">#1F6FEB</Color>
  <Color x:Key="AccentSubtleColor">#12294E</Color>
  <Color x:Key="AccentBorderColor">#1F6FEB</Color>

  <!-- ── Semantic — perceptibly distinct subtle backgrounds ────────────── -->
  <Color x:Key="SuccessColor">#3FB950</Color>
  <Color x:Key="SuccessSubtleColor">#1A3A26</Color>
  <Color x:Key="SuccessBorderColor">#238636</Color>

  <Color x:Key="WarningColor">#D29922</Color>
  <Color x:Key="WarningSubtleColor">#3A2E00</Color>
  <Color x:Key="WarningBorderColor">#9A6700</Color>

  <Color x:Key="DangerColor">#F85149</Color>
  <Color x:Key="DangerSubtleColor">#3D0C0C</Color>
  <Color x:Key="DangerBorderColor">#DA3633</Color>

  <Color x:Key="InfoColor">#58A6FF</Color>
  <Color x:Key="InfoSubtleColor">#0D2045</Color>
  <Color x:Key="InfoBorderColor">#1F6FEB</Color>
  <Color x:Key="PurpleColor">#BC8CFF</Color>

  <!-- ── Step / wizard state ──────────────────────────────────────────── -->
  <Color x:Key="StepActiveColor">#2F81F7</Color>
  <Color x:Key="StepCompletedColor">#3FB950</Color>
  <Color x:Key="StepPendingColor">#4E4E52</Color>
  <Color x:Key="StepErrorColor">#F85149</Color>

  <!-- ═══════════════════════════════════════════════════════════════════
       BRUSHES — canonical new names
       ═══════════════════════════════════════════════════════════════════ -->
  <SolidColorBrush x:Key="BackgroundCanvasBrush"    Color="{StaticResource BackgroundCanvasColor}"/>
  <SolidColorBrush x:Key="BackgroundSurfaceBrush"   Color="{StaticResource BackgroundSurfaceColor}"/>
  <SolidColorBrush x:Key="BackgroundElevatedBrush"  Color="{StaticResource BackgroundElevatedColor}"/>
  <SolidColorBrush x:Key="BackgroundOverlayBrush"   Color="{StaticResource BackgroundOverlayColor}"/>
  <SolidColorBrush x:Key="BackgroundHoverBrush"     Color="{StaticResource BackgroundHoverColor}"/>
  <SolidColorBrush x:Key="BorderSubtleBrush"        Color="{StaticResource BorderSubtleColor}"/>
  <SolidColorBrush x:Key="BorderDefaultBrush"       Color="{StaticResource BorderDefaultColor}"/>
  <SolidColorBrush x:Key="BorderMutedBrush"         Color="{StaticResource BorderMutedColor}"/>
  <SolidColorBrush x:Key="BorderStrongBrush"        Color="{StaticResource BorderStrongColor}"/>
  <SolidColorBrush x:Key="AccentPrimaryBrush"       Color="{StaticResource AccentPrimaryColor}"/>
  <SolidColorBrush x:Key="AccentPrimaryHoverBrush"  Color="{StaticResource AccentPrimaryHoverColor}"/>
  <SolidColorBrush x:Key="AccentSubtleBrush"        Color="{StaticResource AccentSubtleColor}"/>
  <SolidColorBrush x:Key="AccentBorderBrush"        Color="{StaticResource AccentBorderColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush"         Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush"       Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="TextMutedBrush"           Color="{StaticResource TextMutedColor}"/>
  <SolidColorBrush x:Key="TextDisabledBrush"        Color="{StaticResource TextDisabledColor}"/>
  <SolidColorBrush x:Key="TextLinkBrush"            Color="{StaticResource TextLinkColor}"/>
  <SolidColorBrush x:Key="SuccessBrush"             Color="{StaticResource SuccessColor}"/>
  <SolidColorBrush x:Key="SuccessSubtleBrush"       Color="{StaticResource SuccessSubtleColor}"/>
  <SolidColorBrush x:Key="SuccessBorderBrush"       Color="{StaticResource SuccessBorderColor}"/>
  <SolidColorBrush x:Key="WarningBrush"             Color="{StaticResource WarningColor}"/>
  <SolidColorBrush x:Key="WarningSubtleBrush"       Color="{StaticResource WarningSubtleColor}"/>
  <SolidColorBrush x:Key="WarningBorderBrush"       Color="{StaticResource WarningBorderColor}"/>
  <SolidColorBrush x:Key="DangerBrush"              Color="{StaticResource DangerColor}"/>
  <SolidColorBrush x:Key="DangerSubtleBrush"        Color="{StaticResource DangerSubtleColor}"/>
  <SolidColorBrush x:Key="DangerBorderBrush"        Color="{StaticResource DangerBorderColor}"/>
  <SolidColorBrush x:Key="InfoBrush"                Color="{StaticResource InfoColor}"/>
  <SolidColorBrush x:Key="InfoSubtleBrush"          Color="{StaticResource InfoSubtleColor}"/>
  <SolidColorBrush x:Key="InfoBorderBrush"          Color="{StaticResource InfoBorderColor}"/>
  <SolidColorBrush x:Key="PurpleBrush"              Color="{StaticResource PurpleColor}"/>
  <SolidColorBrush x:Key="StepErrorBrush"           Color="{StaticResource StepErrorColor}"/>
  <SolidColorBrush x:Key="TransparentBrush"         Color="Transparent"/>

  <!-- Legacy alias brushes — existing views keep binding to old names ──── -->
  <SolidColorBrush x:Key="BackgroundDeepBrush"      Color="{StaticResource BackgroundCanvasColor}"/>
  <SolidColorBrush x:Key="BackgroundPanelBrush"     Color="{StaticResource BackgroundSurfaceColor}"/>
  <SolidColorBrush x:Key="BackgroundCardBrush"      Color="{StaticResource BackgroundElevatedColor}"/>
  <SolidColorBrush x:Key="InputFieldBrush"          Color="{StaticResource InputFieldColor}"/>
  <SolidColorBrush x:Key="InputForegroundBrush"     Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="InputBackgroundBrush"     Color="{StaticResource InputFieldColor}"/>
  <SolidColorBrush x:Key="InputBorderBrush"         Color="{StaticResource BorderDefaultColor}"/>
  <SolidColorBrush x:Key="InputBorderFocusBrush"    Color="{StaticResource AccentPrimaryColor}"/>
  <SolidColorBrush x:Key="InputSelectionBrush"      Color="{StaticResource AccentPrimaryColor}"/>
  <SolidColorBrush x:Key="InputSelectionTextBrush"  Color="#FFFFFF"/>
  <SolidColorBrush x:Key="InputCaretBrush"          Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="AccentGradientBrush"      Color="{StaticResource AccentPrimaryColor}"/>
  <SolidColorBrush x:Key="SidebarGradientBrush"     Color="{StaticResource BackgroundSurfaceColor}"/>
  <SolidColorBrush x:Key="HeaderGradientBrush"      Color="{StaticResource BackgroundSurfaceColor}"/>
  <SolidColorBrush x:Key="ScanModeRealBrush"        Color="{StaticResource SuccessSubtleColor}"/>
  <SolidColorBrush x:Key="ScanModeSimulationBrush"  Color="{StaticResource WarningSubtleColor}"/>

</ResourceDictionary>
