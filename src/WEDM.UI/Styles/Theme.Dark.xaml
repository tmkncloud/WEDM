<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="BackgroundDeepColor">#0F172A</Color>
  <Color x:Key="BackgroundPanelColor">#111827</Color>
  <Color x:Key="BackgroundCardColor">#111827</Color>
  <Color x:Key="BackgroundElevatedColor">#1F2937</Color>
  <Color x:Key="BackgroundHoverColor">#243044</Color>
  <Color x:Key="InputFieldColor">#1F2937</Color>

  <Color x:Key="BorderSubtleColor">#1F2937</Color>
  <Color x:Key="BorderDefaultColor">#374151</Color>
  <Color x:Key="BorderMutedColor">#4B5563</Color>

  <Color x:Key="AccentPrimaryColor">#3B82F6</Color>
  <Color x:Key="AccentPrimaryHoverColor">#60A5FA</Color>
  <Color x:Key="AccentPrimaryActiveColor">#2563EB</Color>
  <Color x:Key="AccentSubtleColor">#1E3A5F</Color>

  <Color x:Key="TextPrimaryColor">#E5E7EB</Color>
  <Color x:Key="TextSecondaryColor">#94A3B8</Color>
  <Color x:Key="TextMutedColor">#6B7280</Color>
  <Color x:Key="TextLinkColor">#60A5FA</Color>

  <Color x:Key="SuccessColor">#22C55E</Color>
  <Color x:Key="SuccessSubtleColor">#14532D</Color>
  <Color x:Key="WarningColor">#EAB308</Color>
  <Color x:Key="WarningSubtleColor">#422006</Color>
  <Color x:Key="DangerColor">#EF4444</Color>
  <Color x:Key="DangerSubtleColor">#450A0A</Color>
  <Color x:Key="InfoColor">#3B82F6</Color>
  <Color x:Key="PurpleColor">#8B5CF6</Color>

  <Color x:Key="StepActiveColor">#3B82F6</Color>
  <Color x:Key="StepCompletedColor">#22C55E</Color>
  <Color x:Key="StepPendingColor">#4B5563</Color>
  <Color x:Key="StepErrorColor">#EF4444</Color>

  <SolidColorBrush x:Key="BackgroundDeepBrush" Color="{StaticResource BackgroundDeepColor}"/>
  <SolidColorBrush x:Key="BackgroundPanelBrush" Color="{StaticResource BackgroundPanelColor}"/>
  <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCardColor}"/>
  <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{StaticResource BackgroundElevatedColor}"/>
  <SolidColorBrush x:Key="BackgroundHoverBrush" Color="{StaticResource BackgroundHoverColor}"/>
  <SolidColorBrush x:Key="InputFieldBrush" Color="{StaticResource InputFieldColor}"/>
  <SolidColorBrush x:Key="InputForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputFieldColor}"/>
  <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource BorderDefaultColor}"/>
  <SolidColorBrush x:Key="InputBorderFocusBrush" Color="{StaticResource AccentPrimaryColor}"/>
  <SolidColorBrush x:Key="InputSelectionBrush" Color="{StaticResource AccentPrimaryColor}"/>
  <SolidColorBrush x:Key="InputSelectionTextBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="InputCaretBrush" Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>
  <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}"/>
  <SolidColorBrush x:Key="BorderMutedBrush" Color="{StaticResource BorderMutedColor}"/>
  <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}"/>
  <SolidColorBrush x:Key="AccentPrimaryHoverBrush" Color="{StaticResource AccentPrimaryHoverColor}"/>
  <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
  <SolidColorBrush x:Key="TextLinkBrush" Color="{StaticResource TextLinkColor}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
  <SolidColorBrush x:Key="SuccessSubtleBrush" Color="{StaticResource SuccessSubtleColor}"/>
  <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
  <SolidColorBrush x:Key="WarningSubtleBrush" Color="{StaticResource WarningSubtleColor}"/>
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
  <SolidColorBrush x:Key="DangerSubtleBrush" Color="{StaticResource DangerSubtleColor}"/>
  <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
  <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource PurpleColor}"/>
  <SolidColorBrush x:Key="StepErrorBrush" Color="{StaticResource StepErrorColor}"/>
  <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="AccentGradientBrush" Color="{StaticResource AccentPrimaryColor}"/>
  <SolidColorBrush x:Key="SidebarGradientBrush" Color="{StaticResource BackgroundPanelColor}"/>
  <SolidColorBrush x:Key="HeaderGradientBrush" Color="{StaticResource BackgroundPanelColor}"/>
  <SolidColorBrush x:Key="ScanModeRealBrush" Color="{StaticResource SuccessSubtleColor}"/>
  <SolidColorBrush x:Key="ScanModeSimulationBrush" Color="{StaticResource WarningSubtleColor}"/>
</ResourceDictionary>
