<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Panel card (standard surface) -->
    <Style x:Key="MigrationPanelCard" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource BackgroundElevatedBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="14,12"/>
    </Style>

    <!-- Accent card (info/brand context) -->
    <Style x:Key="MigrationAccentCard" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource AccentSubtleBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource AccentBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="14,12"/>
    </Style>

    <!-- Large metric value -->
    <Style x:Key="MigrationMetricValue" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"    Value="26"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <!-- Section heading inside migration views -->
    <Style x:Key="MigrationSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="Margin"      Value="0,0,0,8"/>
    </Style>

    <!-- Status banner (scan mode / general status) -->
    <Style x:Key="MigrationStatusBanner" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource BackgroundElevatedBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="5"/>
        <Setter Property="Padding"          Value="12,8"/>
    </Style>

</ResourceDictionary>
